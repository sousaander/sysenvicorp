<IfModule mod_rewrite.c>
    RewriteEngine On

    # Removemos o RewriteBase fixo para que funcione tanto em subpastas quanto no domínio raiz
    # RewriteBase / 

    # Redireciona todas as requisições que não são um arquivo ou diretório existente para o index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Para o arquivo index.php (ajuste o caminho se necessário)
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>